package logout

import (
	"fmt"

	"github.com/spf13/cobra"

	"{{.Module}}/pkg/config"
)

var Cmd = &cobra.Command{
	Use:   "logout",
	Short: "Log out",
	Long:  "Log out, removing credentials from the config file.",
	Args:  cobra.NoArgs,
	RunE:  run,
}

func run(cmd *cobra.Command, argv []string) error {
	cfg, err := config.Load()
	if err != nil {
		return fmt.Errorf("can't load configuration file: %w", err)
	}

	cfg.Disarm()

	err = config.Save(cfg)
	if err != nil {
		return fmt.Errorf("can't save configuration file: %w", err)
	}

	return nil
}
