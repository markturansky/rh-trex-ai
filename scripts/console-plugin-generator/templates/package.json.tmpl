{
  "name": "{{.PluginName}}",
  "version": "0.0.1",
  "description": "OpenShift Console plugin for {{.DisplayName}}",
  "private": true,
  "license": "Apache-2.0",
  "scripts": {
    "clean": "rm -rf dist",
    "build": "yarn clean && NODE_ENV=production yarn webpack",
    "build-dev": "yarn clean && yarn webpack",
    "start": "yarn webpack serve --progress",
    "lint": "yarn eslint src --fix",
    "webpack": "node -r ts-node/register ./node_modules/.bin/webpack"
  },
  "devDependencies": {
    "@openshift-console/dynamic-plugin-sdk": "1.7.0",
    "@openshift-console/dynamic-plugin-sdk-webpack": "1.3.0",
    "@patternfly/react-core": "^6.0.0",
    "@patternfly/react-icons": "^6.0.0",
    "@patternfly/react-table": "^6.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/react-helmet": "^6.1.6",
    "@types/react-router-dom": "^5.3.3",
    "copy-webpack-plugin": "^12.0.0",
    "css-loader": "^7.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-helmet": "^6.1.0",
    "react-router-dom": "^5.3.4",
    "style-loader": "^4.0.0",
    "ts-loader": "^9.5.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.3.0",
    "webpack": "^5.90.0",
    "webpack-cli": "^5.1.0",
    "webpack-dev-server": "^5.0.0"
  },
  "consolePlugin": {
    "name": "{{.PluginName}}",
    "version": "0.0.1",
    "displayName": "{{.DisplayName}}",
    "description": "OpenShift Console plugin for managing {{.Project}} resources",
    "exposedModules": {
      "App": "./components/App"{{range .Resources}},
      "{{.Name}}ListPage": "./components/{{.Name}}ListPage",
      "{{.Name}}DetailsPage": "./components/{{.Name}}DetailsPage",
      "{{.Name}}CreatePage": "./components/{{.Name}}CreatePage"{{end}}
    },
    "dependencies": {
      "@console/pluginAPI": "*"
    }
  }
}
