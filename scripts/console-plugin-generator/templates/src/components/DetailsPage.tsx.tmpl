import * as React from 'react';
import { useParams, useHistory } from 'react-router-dom';
import {
  Breadcrumb,
  BreadcrumbItem,
{{- if .Resource.HasDelete}}
  Button,
{{- end}}
  DescriptionList,
  DescriptionListDescription,
  DescriptionListGroup,
  DescriptionListTerm,
  Divider,
  Flex,
  FlexItem,
  PageSection,
  Spinner,
  Title,
} from '@patternfly/react-core';
import { createAPIClient } from '../utils/api';
import { useApiToken } from '../hooks/useApiAuth';

function formatDate(value: unknown): string {
  if (!value) return '';
  const d = new Date(String(value));
  return isNaN(d.getTime()) ? String(value) : d.toLocaleString();
}

const {{.Resource.Name}}DetailsPage: React.FC = () => {
  const { id } = useParams<{ id: string }>();
  const token = useApiToken();
  const history = useHistory();
  const [item, setItem] = React.useState<Record<string, unknown> | null>(null);
  const [loading, setLoading] = React.useState(true);
  const [error, setError] = React.useState<string | null>(null);

  React.useEffect(() => {
    if (!token || !id) return;
    setLoading(true);
    const api = createAPIClient(token);
    api.{{.Resource.PluralLower}}.get(id)
      .then((data) => { setItem(data); setError(null); })
      .catch((err) => setError(err instanceof Error ? err.message : String(err)))
      .finally(() => setLoading(false));
  }, [token, id]);

{{- if .Resource.HasDelete}}

  const handleDelete = async () => {
    if (!token || !id) return;
    if (!window.confirm('Are you sure you want to delete this {{.Resource.NameLower}}?')) return;
    try {
      const api = createAPIClient(token);
      await api.{{.Resource.PluralLower}}.delete(id);
      history.push('/{{$.PluginName}}/{{.Resource.PluralKebab}}');
    } catch (err) {
      setError(err instanceof Error ? err.message : String(err));
    }
  };
{{- end}}

  if (loading) {
    return (
      <PageSection>
        <Spinner size="lg" />
      </PageSection>
    );
  }

  if (error) {
    return (
      <PageSection>
        <Title headingLevel="h2">Error</Title>
        <p>{error}</p>
      </PageSection>
    );
  }

  if (!item) return null;

  return (
    <>
      <PageSection variant="light">
        <Breadcrumb>
          <BreadcrumbItem
            onClick={() => history.push('/{{$.PluginName}}/{{.Resource.PluralKebab}}')}
            component="button"
          >
            {{.Resource.Plural}}
          </BreadcrumbItem>
          <BreadcrumbItem isActive>{id}</BreadcrumbItem>
        </Breadcrumb>
        <Flex>
          <FlexItem>
            <Title headingLevel="h1">{{.Resource.Name}} Details</Title>
          </FlexItem>
{{- if .Resource.HasDelete}}
          <FlexItem align={{"{{"}} default: 'alignRight' {{"}}"}}>

            <Button variant="danger" onClick={handleDelete}>Delete</Button>
          </FlexItem>
{{- end}}
        </Flex>
      </PageSection>
      <Divider />
      <PageSection>
        <DescriptionList isHorizontal>
          <DescriptionListGroup>
            <DescriptionListTerm>ID</DescriptionListTerm>
            <DescriptionListDescription>{String(item.id)}</DescriptionListDescription>
          </DescriptionListGroup>
{{- range .Resource.Columns}}
{{- if ne .Name "id"}}
          <DescriptionListGroup>
            <DescriptionListTerm>{{.Header}}</DescriptionListTerm>
            <DescriptionListDescription>
              {{'{'}}{{if eq .FieldType "date-time"}}formatDate(item['{{.JSONPath}}']){{else}}String(item['{{.JSONPath}}'] ?? ''){{end}}{{'}'}}
            </DescriptionListDescription>
          </DescriptionListGroup>
{{- end}}
{{- end}}
          <DescriptionListGroup>
            <DescriptionListTerm>Updated</DescriptionListTerm>
            <DescriptionListDescription>{formatDate(item.updated_at)}</DescriptionListDescription>
          </DescriptionListGroup>
        </DescriptionList>
      </PageSection>
    </>
  );
};

export default {{.Resource.Name}}DetailsPage;
