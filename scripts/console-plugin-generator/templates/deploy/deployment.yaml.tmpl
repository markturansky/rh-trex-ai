apiVersion: apps/v1
kind: Deployment
metadata:
  name: {{.PluginName}}
  labels:
    app: {{.PluginName}}
    app.kubernetes.io/name: {{.PluginName}}
    app.kubernetes.io/part-of: {{.Project}}
spec:
  replicas: 1
  selector:
    matchLabels:
      app: {{.PluginName}}
  template:
    metadata:
      labels:
        app: {{.PluginName}}
    spec:
      containers:
        - name: {{.PluginName}}
          image: REPLACE_WITH_IMAGE
          ports:
            - containerPort: 9443
              protocol: TCP
          resources:
            requests:
              cpu: 10m
              memory: 50Mi
            limits:
              cpu: 100m
              memory: 128Mi
          volumeMounts:
            - name: plugin-serving-cert
              readOnly: true
              mountPath: /var/cert
            - name: nginx-conf
              readOnly: true
              mountPath: /etc/nginx/nginx.conf
              subPath: nginx.conf
      volumes:
        - name: plugin-serving-cert
          secret:
            secretName: {{.PluginName}}-cert
            defaultMode: 420
        - name: nginx-conf
          configMap:
            name: {{.PluginName}}-nginx
            defaultMode: 420
